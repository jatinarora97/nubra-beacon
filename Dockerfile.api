# syntax=docker/dockerfile:1
# Nubra Beacon backend image: read API plus the scheduled pipeline.
# Playwright Chromium supports the existing old.reddit collector.
FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1 \
    PLAYWRIGHT_BROWSERS_PATH=/ms-playwright \
    HF_HOME=/hf-cache

WORKDIR /app

# CPU-only torch avoids the multi-GB CUDA wheels from the default index.
# BuildKit cache mounts are external to the image and let interrupted builds
# reuse already downloaded wheels.
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install torch --index-url https://download.pytorch.org/whl/cpu

COPY requirements.txt .
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -r requirements.txt \
 && playwright install --with-deps chromium

COPY cm runner.py ./
COPY community ./community
COPY migrations ./migrations
COPY scripts ./scripts
COPY data ./data
RUN chmod +x cm && mkdir -p out/messages /hf-cache

EXPOSE 8400
CMD ["python", "-m", "uvicorn", "community.api.read_api:app", \
     "--host", "0.0.0.0", "--port", "8400"]
