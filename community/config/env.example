# Nubra Community Manager — .env template (copy values into the repo-root .env)
# Secrets NEVER go in git; .env is gitignored.

ANTHROPIC_API_KEY=sk-ant-...
TWITTERAPI_IO_KEY=...

DB_URL=postgresql://community:community@localhost:5544/nubra_community
OUT_DIR=out/messages

# ── LLM tracing (unset = Langfuse disabled; llm_usage table always written) ──
# Keys from a NEW Langfuse project named "nubra-beacon" (cloud.langfuse.com →
# New project). Deliberately a SEPARATE stream from nubra-ai-personalization.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── dispatch channels (unset = channel skipped; archive always written) ──
# Slack incoming webhook for the heads-up/roundup channel
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/xxxx
# Gmail sender + app password (myaccount.google.com → Security → App passwords)
# GMAIL_SENDER=team@nubra.in
# GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
# recipients list lives in community/config/registry.yaml → delivery.email_recipients
